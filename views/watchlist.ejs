<div class="row mb-4 align-items-center">
  <div class="col-md-4">
    <h2 class="fw-bold mb-3 mb-md-0">
      <span style="color: var(--accent-crimson);">My</span> Watchlist
    </h2>
  </div>
  
  <div class="col-md-8 d-flex justify-content-md-end">
    <div class="btn-group shadow-sm" role="group" aria-label="Watchlist Filters">
      <a href="/watchlist" class="btn <%= currentFilter === 'All' ? 'btn-primary fw-bold' : 'btn-outline-secondary text-light' %>">All</a>
      <a href="/watchlist?status=Watching" class="btn <%= currentFilter === 'Watching' ? 'btn-primary fw-bold' : 'btn-outline-secondary text-light' %>">Watching</a>
      <a href="/watchlist?status=Plan to Watch" class="btn <%= currentFilter === 'Plan to Watch' ? 'btn-primary fw-bold' : 'btn-outline-secondary text-light' %>">Plan to Watch</a>
      <a href="/watchlist?status=Completed" class="btn <%= currentFilter === 'Completed' ? 'btn-primary fw-bold' : 'btn-outline-secondary text-light' %>">Completed</a>
      <a href="/watchlist?status=Dropped" class="btn <%= currentFilter === 'Dropped' ? 'btn-primary fw-bold' : 'btn-outline-secondary text-light' %>">Dropped</a>
    </div>
  </div>
  <div class="col-12 mt-3">
    <hr class="border-secondary m-0">
  </div>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<% if (items && items.length > 0) { %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    <% items.forEach(item => { %>
      <div class="col">
        <div class="card h-100 surface-element position-relative">
          
          <form action="/watchlist/delete/<%= item._id %>" method="POST" class="position-absolute top-0 end-0 p-2" onsubmit="return confirm('Remove <%= item.title %> from your list?');" style="z-index: 10;">
            <button type="submit" class="btn btn-sm btn-danger rounded-circle" title="Remove Item">✕</button>
          </form>

          <a href="/details/<%= item.mediaType %>/<%= item.externalApiId %>" class="text-decoration-none text-light">
            <% if (item.poster_url) { %>
              <img src="https://image.tmdb.org/t/p/w500<%= item.poster_url %>" class="card-img-top" alt="<%= item.title %>" style="max-height: 350px; object-fit: cover;">
            <% } else { %>
              <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 350px;">
                <span class="text-light">No Image</span>
              </div>
            <% } %>
          </a>

          <div class="card-body d-flex flex-column">
            
            <a href="/details/<%= item.mediaType %>/<%= item.externalApiId %>" class="text-decoration-none text-light">
              <h5 class="card-title fw-bold text-truncate" title="<%= item.title %>"><%= item.title %></h5>
            </a>
            
            <form action="/watchlist/update/<%= item._id %>" method="POST" class="mt-auto">
              
              <div class="mb-2 mt-3">
                <label class="form-label small text-light opacity-75 mb-1">Status</label>
                <select name="status" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="this.form.submit()">
                  <option value="Plan to Watch" <%= item.status === 'Plan to Watch' ? 'selected' : '' %>>Plan to Watch</option>
                  <option value="Watching" <%= item.status === 'Watching' ? 'selected' : '' %>>Watching</option>
                  <option value="Completed" <%= item.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                  <option value="Dropped" <%= item.status === 'Dropped' ? 'selected' : '' %>>Dropped</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label small text-light opacity-75 mb-1">Rating (1-10)</label>
                <select name="rating" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="this.form.submit()">
                  <option value="">Unrated</option>
                  <% for(let i = 1; i <= 10; i++) { %>
                    <option value="<%= i %>" <%= item.rating === i ? 'selected' : '' %>><%= i %> / 10</option>
                  <% } %>
                </select>
              </div>
              
              <noscript><button type="submit" class="btn btn-sm btn-primary w-100">Update</button></noscript>
            </form>

          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <div class="text-center mt-5">
    <h4 class="text-muted">Your watchlist is currently empty.</h4>
    <p class="text-muted mb-4">Time to find your next obsession.</p>
    <a href="/search" class="btn btn-primary px-4 py-2 fw-bold">Explore Content</a>
  </div>
<% } %>