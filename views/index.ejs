<div class="container col-xxl-8 px-4 py-5 mt-4">
  <div class="row align-items-center g-5 py-5 text-center">
    <div class="col-lg-8 mx-auto">
      
      <h1 class="display-3 fw-bold mb-4">
        Master Your Queue<br>with <span style="color: var(--accent-crimson);">WatchSensei</span>
      </h1>
      
      <p class="lead text-light opacity-75 mb-5 mx-auto" style="max-width: 650px;">
        Your ultimate mid-term companion for tracking movies and anime. Discover live content, build your personal watchlist, and rate your favorites in a seamless, dark-mode experience.
      </p>
      
      <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
        <% if (currentUser) { %>
          <a href="/search" class="btn btn-primary btn-lg px-5 fw-bold rounded-pill">Discover Content</a>
          <a href="/watchlist" class="btn btn-outline-light btn-lg px-5 rounded-pill">My Watchlist</a>
        <% } else { %>
          <a href="/auth/register" class="btn btn-primary btn-lg px-5 fw-bold rounded-pill">Start Tracking Now</a>
          <a href="/search" class="btn btn-outline-light btn-lg px-5 rounded-pill">Explore as Guest</a>
        <% } %>
      </div>

    </div>
  </div>
</div>

<% if (typeof trendingPreviews !== 'undefined' && trendingPreviews && trendingPreviews.length > 0) { %>
  <div class="container mt-2 mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <h3 class="fw-bold mb-0">🔥 Trending Today</h3>
      <a href="/search" class="text-light text-decoration-none opacity-75 small">View All &raquo;</a>
    </div>
    
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3">
      <% trendingPreviews.forEach(item => { %>
        <div class="col">
          <a href="/details/<%= item.media_type %>/<%= item.id %>" class="text-decoration-none">
            <div class="card bg-transparent border-0 position-relative overflow-hidden" style="border-radius: 10px; transition: transform 0.2s;">
              <img src="https://image.tmdb.org/t/p/w500<%= item.poster_path %>" class="img-fluid rounded shadow-sm" alt="<%= item.title || item.name %>">
              
              <div class="position-absolute bottom-0 w-100 p-2 text-center" style="background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); opacity: 0.9;">
                <span class="small text-light fw-bold text-truncate d-block"><%= item.title || item.name %></span>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>
<div class="row g-4 py-5 row-cols-1 row-cols-lg-3 mt-4 border-top border-secondary">
  <div class="col text-center">
    <div class="card h-100 surface-element p-4 border-0">
      <h4 class="fw-bold mb-3">Live Search</h4>
      <p class="text-light opacity-75">Powered by the TMDB API to pull real-time data for both movies and anime across the globe.</p>
    </div>
  </div>
  <div class="col text-center">
    <div class="card h-100 surface-element p-4 border-0">
      <h4 class="fw-bold mb-3">Personalized Lists</h4>
      <p class="text-light opacity-75">Secure user authentication ensures your "Plan to Watch" and "Completed" lists remain entirely your own.</p>
    </div>
  </div>
  <div class="col text-center">
    <div class="card h-100 surface-element p-4 border-0">
      <h4 class="fw-bold mb-3">Midnight Design</h4>
      <p class="text-light opacity-75">Built with a custom dark-mode design system to keep things easy on the eyes during late-night binges.</p>
    </div>
  </div>
</div>