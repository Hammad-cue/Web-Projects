<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WatchSensei</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --bg-charcoal: #121212;
      --surface-card: #1E1E1E;
      --text-main: #F8F9FA;
      --accent-crimson: #E50914;
    }

    body {
      background-color: var(--bg-charcoal);
      color: var(--text-main);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Card Styling */
    .card,
    .surface-element {
      background-color: var(--surface-card);
      border: none;
      color: var(--text-main);
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    }

    /* Buttons */
    .btn-primary {
      background-color: var(--accent-crimson);
      border-color: var(--accent-crimson);
      color: var(--text-main);
    }

    .btn-primary:hover,
    .btn-primary:active,
    .btn-primary:focus {
      background-color: #b80710;
      border-color: #b80710;
    }

    /* Navigation */
    .navbar {
      background-color: var(--surface-card);
      
    }

    .navbar-brand,
    .nav-link {
      color: var(--text-main) !important;
    }

    .nav-link:hover {
      color: var(--accent-crimson) !important;
    }

    /* Main Content Wrapper */
    main {
      flex: 1;
    }

    .full-width-breakout {
      width: 100vw !important;
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw !important;
      margin-right: -50vw !important;
    }

    /* =========================================
   WATCHSENSEI PREMIUM UI ENHANCEMENTS
   ========================================= */

    /* 1. Glassmorphism Cards (Depth & Elegance) */
    .surface-element {
      background: rgba(30, 30, 35, 0.6) !important;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.08) !important;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    /* 2. Interactive KPI Hover States */
    .surface-element:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 15px rgba(229, 9, 20, 0.1);
    }

    /* 3. Sleek Custom Scrollbars (Crucial for Dark Mode) */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #121212;
    }

    ::-webkit-scrollbar-thumb {
      background: #333;
      border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--accent-crimson, #e50914);
    }

    /* 4. Cinematic Poster Hover Effects (For your Drill-Down Grid) */
    .hover-zoom {
      transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
      cursor: pointer;
      border-radius: 8px;
    }

    .hover-zoom:hover {
      transform: scale(1.08) translateY(-5px);
      box-shadow: 0 15px 25px rgba(0, 0, 0, 0.5);
      z-index: 10;
    }

    /* 5. Smooth Drill-Down Reveal Animation */
    @keyframes slideDownFade {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    #drillDownSection:not(.d-none) {
      animation: slideDownFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    /* 6. CUSTOM NAVBAR UNDERLINE (Animated Active States) */
    .custom-nav-link {
      position: relative;
      padding-bottom: 5px !important;
      transition: color 0.3s ease;
    }
    
    .custom-nav-link::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: 0;
      left: 50%;
      background-color: var(--accent-crimson, #e50914);
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      transform: translateX(-50%);
    }

    .custom-nav-link:hover::after,
    .custom-nav-link.active-link::after {
      width: 100%;
    }

    .custom-nav-link.active-link {
      color: #ffffff !important;
      font-weight: 600;
    }
  </style>
</head>

<body>

 <nav class="navbar navbar-expand-lg navbar-dark position-absolute w-100 z-3 bg-transparent py-2">
  <div class="container-fluid px-4 px-lg-5">
    
    <a class="navbar-brand fw-bold fs-4" href="/">
      <span style="color: var(--accent-crimson);">Watch</span>Sensei
    </a>

    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      
      <ul class="navbar-nav mx-auto align-items-center gap-4" id="main-nav-links">
        <li class="nav-item">
          <a class="nav-link text-light fs-6 custom-nav-link" href="/" style="letter-spacing: 0.5px;">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-light fs-6 custom-nav-link" href="/search" style="letter-spacing: 0.5px;">Explore</a>
        </li>
        
        <% if (currentUser) { %>
          <li class="nav-item">
            <a class="nav-link text-light fs-6 custom-nav-link" href="/watchlist" style="letter-spacing: 0.5px;">My Watchlist</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-light fs-6 custom-nav-link" href="/profile" style="letter-spacing: 0.5px;">My Stats</a>
          </li>
        <% } %>
      </ul>

      <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
        <% if (currentUser) { %>
          <div class="bg-dark border border-secondary border-opacity-50 rounded-circle d-flex align-items-center justify-content-center text-light fw-bold shadow-sm" style="width: 32px; height: 32px; font-size: 0.85rem;" title="<%= currentUser.username %>">
            <%= currentUser.username.charAt(0).toUpperCase() %>
          </div>
          <a href="/auth/logout" class="btn btn-sm btn-outline-light rounded-pill px-3 transition-all">Logout</a>
        <% } else { %>
          <a href="/auth/login" class="text-light text-decoration-none small fw-bold me-2 hover-crimson">Log In</a>
          <a href="/auth/register" class="btn btn-sm btn-primary rounded-pill px-4 fw-bold shadow">Sign Up</a>
        <% } %>
      </div>

    </div>
  </div>
</nav>
  <main class="container" style="padding-top: 100px;">
    <%- body %>
  </main>

  <footer class="text-center py-4 mt-auto">
    <p class="text-muted small mb-0">&copy; 2026 WatchSensei. Mid-term Project.</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll('.custom-nav-link');

      navLinks.forEach(link => {
        // Exact match
        if (link.getAttribute('href') === currentPath) {
          link.classList.add('active-link');
        }
        // Keep "Explore" highlighted if viewing a details page
        else if (currentPath.includes('/details') && link.getAttribute('href') === '/search') {
          link.classList.add('active-link');
        }
      });
    });
  </script>
</body>

</html>