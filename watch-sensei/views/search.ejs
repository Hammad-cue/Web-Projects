<div class="row mb-4">
  <div class="col-12 text-center">
    <h1 class="fw-bold mb-3">Explore <span style="color: var(--accent-crimson);">WatchSensei</span></h1>
    <p class="text-light opacity-75">Search for your favorite movies and anime.</p>
    
    <form action="/search" method="GET" class="d-flex justify-content-center mt-4">
      <div class="input-group w-50">
        <input type="text" name="q" class="form-control bg-dark text-light border-secondary" 
               placeholder="e.g., Attack on Titan, Interstellar..." 
               value="<%= query || '' %>" required>
        <button class="btn btn-primary fw-bold px-4" type="submit">Search</button>
      </div>
    </form>
  </div>
</div>

<% if (error) { %>
  <div class="alert alert-danger text-center"><%= error %></div>
<% } %>

<% if (results && results.length > 0) { %>
  
  <div class="d-flex justify-content-between align-items-end mb-3 mt-4 border-bottom border-secondary pb-2">
    <h3 class="fw-bold mb-0">
      <% if (isTrending) { %>
        🔥 Trending This Week
      <% } else { %>
        Search Results for "<span style="color: var(--accent-crimson);"><%= query %></span>"
      <% } %>
    </h3>
  </div>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mt-2">
    <% results.forEach(item => { %>
      <% if (item.poster_path) { %>
        <div class="col">
          <div class="card h-100 surface-element">
            <a href="/details/<%= item.media_type %>/<%= item.id %>" class="text-decoration-none text-light">
              <img src="https://image.tmdb.org/t/p/w500<%= item.poster_path %>" class="card-img-top" alt="<%= item.title || item.name %>">
            </a>
            <div class="card-body d-flex flex-column">
              <a href="/details/<%= item.media_type %>/<%= item.id %>" class="text-decoration-none text-light">
                <h5 class="card-title fw-bold text-truncate" title="<%= item.title || item.name %>">
                  <%= item.title || item.name %>
                </h5>
              </a>
              <p class="text-light opacity-75 small mb-3">
                <%= item.media_type === 'tv' ? 'TV/Anime' : 'Movie' %> • 
                <%= (item.release_date || item.first_air_date || '').substring(0, 4) %>
              </p>
              <div class="mt-auto">
                <% if (currentUser) { %>
                  <form action="/watchlist/add" method="POST">
                    <input type="hidden" name="externalApiId" value="<%= item.id %>">
                    <input type="hidden" name="title" value="<%= item.title || item.name %>">
                    <input type="hidden" name="poster_url" value="<%= item.poster_path %>">
                    <input type="hidden" name="mediaType" value="<%= item.media_type %>">
                    <button type="submit" class="btn btn-outline-light w-100 btn-sm">+ Add to Watchlist</button>
                  </form>
                <% } else { %>
                  <a href="/auth/login" class="btn btn-outline-secondary w-100 btn-sm">Login to Add</a>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% } %>
    <% }) %>
  </div>
  <% if (totalPages > 1) { %>
  <nav aria-label="Search results pages" class="mt-5 mb-4">
    <ul class="pagination justify-content-center">
      
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link bg-dark text-light border-secondary" 
           href="/search?q=<%= query %>&page=<%= currentPage - 1 %>">
           &laquo; Previous
        </a>
      </li>

      <li class="page-item disabled">
        <span class="page-link surface-element text-light border-secondary">
          Page <%= currentPage %> of <%= totalPages %>
        </span>
      </li>

      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link bg-dark text-light border-secondary" 
           href="/search?q=<%= query %>&page=<%= currentPage + 1 %>">
           Next &raquo;
        </a>
      </li>
      
    </ul>
  </nav>
  <% } %>

<% } else if (query) { %>
  <div class="text-center text-light opacity-75 mt-5">
    <h5>No results found for "<%= query %>".</h5>
    <p>Try checking your spelling or using different keywords.</p>
  </div>
<% } %>