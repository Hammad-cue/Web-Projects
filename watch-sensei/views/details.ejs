<% if (error) { %>
  <div class="alert alert-danger text-center mt-5"><%= error %></div>
<% } else if (data) { %>

  <div class="row position-relative mb-5" style="height: 400px; overflow: hidden; border-radius: 15px;">
    <% if (data.backdrop_path) { %>
      <div class="position-absolute w-100 h-100" style="
        background-image: url('https://image.tmdb.org/t/p/original<%= data.backdrop_path %>');
        background-size: cover;
        background-position: center;
        opacity: 0.4;
        z-index: 0;
      "></div>
      <div class="position-absolute w-100 h-100" style="
        background: linear-gradient(to top, var(--bg-charcoal) 0%, transparent 100%);
        z-index: 1;
      "></div>
    <% } %>
    
    <div class="col-12 d-flex align-items-end p-4 p-md-5" style="z-index: 2;">
      <div>
        <h1 class="display-4 fw-bold mb-2"><%= data.title || data.name %></h1>
        <p class="text-light opacity-75 fs-5 mb-2">
          <%= (data.release_date || data.first_air_date || '').substring(0, 4) %> • 
          <%= data.genres.map(g => g.name).join(', ') %>
          <% if (data.runtime || data.episode_run_time?.length) { %>
             • <%= data.runtime || data.episode_run_time[0] %> mins
          <% } %>
        </p>

       <div class="d-flex flex-wrap gap-2 mt-3">
          <span class="badge bg-dark border border-secondary p-2 fs-6 shadow-sm text-light fw-normal">
            ⭐ TMDB: <%= data.vote_average ? data.vote_average.toFixed(1) : 'N/A' %>/10
          </span>

          <% if (typeof omdbRatings !== 'undefined' && omdbRatings && omdbRatings.length > 0) { %>
            <% omdbRatings.forEach(rating => { %>
              <% 
                // Keep the icons for quick reading, but remove the loud background colors
                let icon = '🍿';
                if (rating.Source === 'Internet Movie Database') icon = '🎬 IMDb:';
                if (rating.Source === 'Rotten Tomatoes') icon = '🍅 RT:';
                if (rating.Source === 'Metacritic') icon = 'Ⓜ️ Meta:'; 
              %>
              <span class="badge bg-dark border border-secondary p-2 fs-6 shadow-sm text-light fw-normal">
                <%= icon %> <%= rating.Value %>
              </span>
            <% }) %>
          <% } %>
        </div>
        </div>
    </div>
  </div>

  <div class="row g-5">
    <div class="col-md-4 col-lg-3 text-center text-md-start">
      <img src="https://image.tmdb.org/t/p/w500<%= data.poster_path %>" class="img-fluid rounded shadow mb-4" alt="Poster">
      
      <% if (currentUser) { %>
        <form action="/watchlist/add" method="POST">
          <input type="hidden" name="externalApiId" value="<%= data.id %>">
          <input type="hidden" name="title" value="<%= data.title || data.name %>">
          <input type="hidden" name="poster_url" value="<%= data.poster_path %>">
          <input type="hidden" name="mediaType" value="<%= type %>">
          <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">
            + Add to Watchlist
          </button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="btn btn-outline-light w-100 py-2">Login to Add</a>
      <% } %>
    </div>

    <div class="col-md-8 col-lg-9">
      <h3 class="fw-bold border-bottom border-secondary pb-2 mb-3">Synopsis</h3>
      <p class="text-light opacity-75 lh-lg mb-5"><%= data.overview %></p>

      <% if (trailer) { %>
        <h3 class="fw-bold border-bottom border-secondary pb-2 mb-3">Official Trailer</h3>
        <div class="ratio ratio-16x9 mb-5 rounded overflow-hidden shadow">
          <iframe src="https://www.youtube.com/embed/<%= trailer %>" allowfullscreen></iframe>
        </div>
      <% } %>

      <h3 class="fw-bold border-bottom border-secondary pb-2 mb-3">Top Cast</h3>
      <div class="row row-cols-2 row-cols-md-4 g-3 mb-5">
        <% if (data.credits && data.credits.cast) { %>
          <% data.credits.cast.slice(0, 4).forEach(actor => { %>
            <div class="col text-center">
              <% if (actor.profile_path) { %>
                <img src="https://image.tmdb.org/t/p/w200<%= actor.profile_path %>" class="img-fluid rounded-circle mb-2 shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" alt="<%= actor.name %>">
              <% } else { %>
                <div class="bg-secondary rounded-circle mb-2 mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                  <span class="small">No Image</span>
                </div>
              <% } %>
              <p class="fw-bold mb-0 small"><%= actor.name %></p>
              <p class="text-light opacity-75 small text-truncate"><%= actor.character %></p>
            </div>
          <% }) %>
        <% } %>
      </div>

      <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
        <h3 class="fw-bold border-bottom border-secondary pb-2 mb-4 mt-5">User Reviews</h3>
        <div class="row g-4 mb-5">
          <% reviews.forEach(review => { %>
            <div class="col-12">
              <div class="card surface-element p-4 border border-secondary border-opacity-25 shadow-sm">
                <div class="d-flex align-items-center mb-3">
                  <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                    <%= review.author.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <h6 class="fw-bold mb-0"><%= review.author %></h6>
                    <small class="text-light opacity-50"><%= new Date(review.created_at).toLocaleDateString() %></small>
                  </div>
                </div>
                
                <p class="text-light opacity-75 small mb-2" style="display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">
                  <%= review.content %>
                </p>
                <a href="<%= review.url %>" target="_blank" class="small text-decoration-none fw-bold" style="color: var(--accent-crimson);">
                  Read full review on TMDB &raquo;
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
      </div>
  </div>

  <% if (data.recommendations && data.recommendations.results && data.recommendations.results.length > 0) { %>
    <div class="row mt-5 mb-5 pt-4 border-top border-secondary border-opacity-25">
      <div class="col-12">
        <h4 class="fw-bold mb-4 text-light">You Might Also Like</h4>
        
        <div class="d-flex flex-nowrap overflow-auto gap-3 pb-3 custom-scrollbar-hide" style="-webkit-overflow-scrolling: touch;">
          
          <% data.recommendations.results.forEach(item => { %>
            <% if (item.poster_path) { %>
              <div class="card bg-transparent border-0 flex-shrink-0" style="width: 160px;">
                
                <a href="/details/<%= item.media_type || type %>/<%= item.id %>" class="text-decoration-none">
                  <div class="position-relative overflow-hidden rounded shadow-sm hover-zoom">
                    <img src="https://image.tmdb.org/t/p/w200<%= item.poster_path %>" class="img-fluid w-100" alt="<%= item.title || item.name %>">
                    
                    <div class="position-absolute bottom-0 w-100 p-2" style="background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);">
                      <span class="badge bg-dark border border-secondary text-warning">
                        ⭐ <%= item.vote_average ? item.vote_average.toFixed(1) : 'NR' %>
                      </span>
                    </div>
                  </div>
                  
                  <p class="text-light small mt-2 fw-bold text-truncate mb-0" title="<%= item.title || item.name %>">
                    <%= item.title || item.name %>
                  </p>
                </a>

              </div>
            <% } %>
          <% }) %>
          
        </div>
      </div>
    </div>
  <% } %>

<% } %>

<style>
  .custom-scrollbar-hide::-webkit-scrollbar {
    height: 6px;
  }
  .custom-scrollbar-hide::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar-hide::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }
  .custom-scrollbar-hide:hover::-webkit-scrollbar-thumb {
    background: rgba(229, 9, 20, 0.5); /* Faint crimson on hover */
  }
</style>