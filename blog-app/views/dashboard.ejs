<%- include('partials/header') %>

<section class="dashboard-header">
    <div>
        <h2 style="margin-bottom: 0;">Welcome, <%= user.username %></h2>
        <p class="sans-text" style="color: var(--text-muted); font-weight: 400; margin-top: 0.5rem;">Your published writing.</p>
    </div>
    <a href="/create-post" class="btn btn-primary">Write a Post</a>
</section>

<section class="post-feed">
    <% if (posts.length === 0) { %>
        <p style="text-align: center; color: var(--text-muted); font-style: italic; margin-top: 4rem;">
            You haven't published anything yet.
        </p>
    <% } else { %>
        <% posts.forEach(post => { %>
            <article class="post-article">
                <% if (post.image) { %>
                    <img src="<%= post.image %>" class="post-image" alt="Cover image for <%= post.title %>">
                <% } %>
                
                <header>
                    <h3 class="post-title"><%= post.title %></h3>
                    <div class="post-meta">
                        By <%= post.author.username %> &mdash; <%= post.createdAt.toDateString() %>
                    </div>
                </header>
                
                <div class="post-content" style="max-height: 150px; overflow: hidden; position: relative;">
                    <%- post.content %>
                    <div style="position: absolute; bottom: 0; left: 0; width: 100%; height: 50px; background: linear-gradient(transparent, var(--bg-warm));"></div>
                </div>
                
                <footer class="post-actions" style="display: flex; gap: 1rem; align-items: center; border-top: 1px solid var(--border-subtle); padding-top: 1.5rem;">
                    <a href="/post/<%= post._id %>" class="btn btn-primary">Read Post</a>
                    
                    <a href="/edit-post/<%= post._id %>" class="btn">Edit</a>
                    <form action="/delete-post/<%= post._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Permanently delete this post?');">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </footer>
            </article>
        <% }) %>
    <% } %>
</section>

<%- include('partials/footer') %>