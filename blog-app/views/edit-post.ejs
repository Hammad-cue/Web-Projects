<%- include('partials/header') %>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<article style="max-width: 600px; margin: 0 auto;">
    <header style="margin-bottom: 3rem;">
        <h2 style="font-size: 2rem; letter-spacing: -0.5px;">Edit Post</h2>
    </header>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert"><%= error %></div>
    <% } %>

    <form id="editForm" action="/edit-post/<%= post._id %>" method="POST" enctype="multipart/form-data">
        
        <div class="form-group">
            <label for="title" class="form-label">Post Title</label>
            <input type="text" class="form-control" id="title" name="title" value="<%= post.title %>" required>
        </div>

        <div class="form-group">
            <label for="image" class="form-label">Update Featured Image (Optional)</label>
            <% if (post.image) { %>
                <div style="margin-bottom: 1rem;">
                    <span class="sans-text" style="font-size: 0.85rem; color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Current image:</span>
                    <img src="<%= post.image %>" alt="Current Image" style="max-height: 120px; border-radius: 3px; border: 1px solid var(--border-subtle);">
                </div>
            <% } %>
            <input class="form-control" type="file" id="image" name="image" accept="image/*" style="padding: 0.5rem;">
        </div>

        <div class="form-group">
            <label class="form-label">Content</label>
            <div id="editor-container" style="height: 350px; font-family: var(--font-serif); font-size: 1.1rem; background: transparent; border-color: var(--border-subtle);"><%- post.content %></div>
            <input type="hidden" name="content" id="hiddenContent">
        </div>

        <div style="display: flex; gap: 1rem; margin-top: 3rem;">
            <button type="submit" class="btn btn-primary">Update Post</button>
            <a href="/dashboard" class="btn">Cancel</a>
        </div>
    </form>
</article>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
    var quill = new Quill('#editor-container', {
        theme: 'snow',
        placeholder: 'Edit your blog post here...'
    });

    var form = document.getElementById('editForm');
    form.onsubmit = function() {
        var contentInput = document.getElementById('hiddenContent');
        contentInput.value = quill.root.innerHTML;
        
        if (quill.getText().trim().length === 0) {
            alert('Post content cannot be empty.');
            return false;
        }
    };
</script>

<%- include('partials/footer') %>