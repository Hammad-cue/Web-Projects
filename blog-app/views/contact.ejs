<%- include('partials/header') %>

<section style="max-width: 500px; margin: 2rem auto 0 auto;">
    <header style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 2.5rem; letter-spacing: -0.5px;">Get in touch</h1>
        <p class="sans-text" style="color: var(--text-muted); font-weight: 400;">Have a question or feedback? We'd love to hear from you.</p>
    </header>

    <form onsubmit="event.preventDefault(); alert('Message sent successfully! We will get back to you soon.'); this.reset();">
        <div class="form-group">
            <label for="name" class="form-label">Name</label>
            <input type="text" class="form-control" id="name" required>
        </div>
        <div class="form-group">
            <label for="email" class="form-label">Email address</label>
            <input type="email" class="form-control" id="email" required>
        </div>
        <div class="form-group">
            <label for="message" class="form-label">Message</label>
            <textarea class="form-control" id="message" rows="5" style="resize: vertical;" required></textarea>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Send Message</button>
    </form>
</section>

<%- include('partials/footer') %>